# Copy to .env for local development (gitignored). In production set these as
# environment variables on the Render service (see render.yaml).

# ── Database: Supabase Postgres (Npgsql connection string) ───────────────────
# Supabase → Project Settings → Database → Connection string → ".NET" / or build
# it from the connection-pooler details. Example shape:
#   Host=aws-0-<region>.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.<ref>;Password=<your-db-password>;SSL Mode=Require;Trust Server Certificate=true
DATABASE_CONNECTION=

# ── Chat: Groq (free API serving open-source Llama) ──────────────────────────
# https://console.groq.com/keys  — if unset, the chat layer falls back to a
# deterministic mock so the app still runs.
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ── Embeddings: Google Gemini (free text-embedding-004, 768-dim) ─────────────
# https://aistudio.google.com/app/apikey  — if unset, embeddings fall back to a
# deterministic mock (768-dim) so local dev works with no keys.
GEMINI_API_KEY=
GEMINI_EMBED_MODEL=text-embedding-004
